# Ruflo MCP Server
RUFLO_PORT=3000

# Compose profiles: "pg" включает PostgreSQL (для ruvector import/export, SQL-доступа).
# Закомментируй или удали строку, чтобы запускаться в lean-режиме (только sql.js).
COMPOSE_PROFILES=pg

# PostgreSQL (используется только при COMPOSE_PROFILES=pg)
POSTGRES_DB=ruflo
POSTGRES_USER=ruflo
POSTGRES_PASSWORD=changeme

# Volume: internal (default) or external path
# Internal (Docker volume):
#   POSTGRES_DATA=ruflo-pgdata
# External (host directory):
#   POSTGRES_DATA=/path/to/data/on/host
POSTGRES_DATA=ruflo-pgdata
